{
    "name": "swiftbill-server",
    "version": "1.0.0",
    "description": "Backend server for SwiftBill restaurant billing system",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "seed": "ts-node src/database/seed.ts",
        "test:db": "ts-node src/config/testConnection.ts",
        "create-admin": "ts-node src/scripts/createAdmin.ts"
    },
    "keywords": [
        "billing",
        "restaurant",
        "pos"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@types/compression": "^1.8.1",
        "bcryptjs": "^2.4.3",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "exceljs": "^4.4.0",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "express-validator": "^7.0.1",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "pdfkit": "^0.14.0",
        "socket.io": "^4.8.3"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/helmet": "^0.0.48",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^20.10.6",
        "@types/pdfkit": "^0.13.4",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
